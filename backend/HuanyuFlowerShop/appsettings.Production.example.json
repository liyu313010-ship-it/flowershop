{
  "JwtSettings": {
    "SecretKey": "inject-from-secret-manager-minimum-32-random-characters",
    "Issuer": "https://flowers.example.com",
    "Audience": "flowers-web",
    "ExpirationInMinutes": 60
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=db;Port=3306;Database=huanyuflowershop;User=flowershop_app;Password=inject-from-secret-manager;SslMode=Required;ConnectionTimeout=10;DefaultCommandTimeout=30"
  },
  "AllowedHosts": "flowers.example.com",
