    "Mode": "disabled",
    "Alipay": {
      "AppId": "",
      "PrivateKey": "",
      "PublicKey": "",
      "NotifyUrl": "https://flowers.example.com/api/payment/alipay/notify"
    }
  },
  "Email": {
    "Enabled": false,
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "From": ""
  },
  "Shipping": {
    "BaseFee": 15,
    "SameDayFee": 20,
    "FreeThreshold": 299,
    "SameDayCutoffHour": 15
  },
  "AdminBootstrap": {
    "Enabled": false,
    "Password": "inject-only-for-one-time-bootstrap"
  }
